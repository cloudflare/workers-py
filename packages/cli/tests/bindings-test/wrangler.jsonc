{
    "name": "bindings-test",
    "main": "src/worker.py",
    "compatibility_date": "%COMPAT_DATE",
    "compatibility_flags": ["python_workers"],
    "kv_namespaces": [
        { "binding": "KV", "id": "test-kv" }
    ],
    "r2_buckets": [
        { "binding": "BUCKET", "bucket_name": "test-bucket" }
    ],
    "d1_databases": [
        {
            "binding": "DB",
            "database_id": "00000000-0000-0000-0000-000000000000",
            "database_name": "test-db"
        }
    ],
    "queues": {
        "producers": [
            { "binding": "TEST_QUEUE", "queue": "test-queue" }
        ],
        "consumers": [
            { "queue": "test-queue", "max_batch_size": 10, "max_batch_timeout": 1 }
        ]
    },
    "durable_objects": {
        "bindings": [
            { "name": "TEST_DO", "class_name": "TestDurableObject" }
        ]
    },
    "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["TestDurableObject"] }
    ]
}
